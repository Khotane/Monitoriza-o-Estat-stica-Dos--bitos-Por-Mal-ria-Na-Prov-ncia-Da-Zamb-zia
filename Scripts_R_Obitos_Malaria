                                    #Vamos verificar Independencia e outocorrelação, com o teste ACF  #


               # vamos criar uma seri temporal primeiro

ts_obitos<-ts(Dados$Obitos, start = c(2017,1 ), frequency = 12)
      
                #funcoes ACF e PACF

par(mfrow = c(1, 2))

acf(ts_obitos, lag.max = 24, main = "ACF - Obitos Por Málaria")

pacf(ts_obitos, lag.max = 24, main="PACF - Obitos Por Málraria")

                       # Teste formal de Ljung-Box
Box.test(ts_obitos, lag = 12, type = "Ljung-Box")
                      #Vamos verificar se a serie é estacionária##########

adf.test(ts_obitos)

#########################################################################################################################################################
##################################################### FASE 4 ####################################################################################################
#                     Avançar com o Modelo ARIMA#

                                # SARIMA automático — deixa o R escolher a melhor ordem

modelo<-auto.arima(ts_obitos, seasonal = T, stepwise = F, approximation = F)
summary(modelo)

Residous<-residuals(modelo)
par(mfrow= c(2,2))
plot(Residous, main="Residous do ARIMA(0.1.2)")
acf(Residous, main = "ACF - Obitos Por Málaria")
pacf(Residous, main="PACF - Obitos Por Málraria")
qqnorm(Residous);qqline(Residous)


# Teste formal nos resíduos

Box.test(Residous, lag=12, type = "Ljung-Box")



#########################################################################################################################################################
##################################################### FASE 5 ####################################################################################################
