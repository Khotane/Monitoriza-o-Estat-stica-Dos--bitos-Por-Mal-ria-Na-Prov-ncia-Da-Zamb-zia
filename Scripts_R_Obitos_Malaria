# ── PODER DO TESTE — CARTA CUSUM ──



# Pergunta: qual a probabilidade de detectar um aumento de X desvios padrão?

# ARL fora de controlo para diferentes desvios
desvios <- c(0.5, 1.0, 1.5, 2.0, 2.5, 3.0)

arl_cusum <- sapply(desvios, function(d) {
  xcusum.arl(k = 0.5,        # parâmetro de referência
             h = 4,           # intervalo de decisão
             mu = d)          # desvio a detectar (em nº de sigma)
})

# ARL fora de controlo para EWMA
arl_ewma <- sapply(desvios, function(d) {
  xewma.arl(l      = 0.2,    # lambda
            c      = 2.962,  # limite de controlo (3 sigma)
            mu     = d)      # desvio a detectar
})

# Tabela de resultados
tabela_arl <- data.frame(
  Desvio_sigma    = desvios,
  ARL_CUSUM       = round(arl_cusum, 2),
  ARL_EWMA        = round(arl_ewma,  2)
)

print(tabela_arl)


